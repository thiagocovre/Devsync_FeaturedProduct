<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        Bind the stock service contract to its MSI implementation.
        Swap this preference to change the real-time inventory source without
        touching any consumer (block / view model / controller).
    -->
    <preference for="Devsync\FeaturedProduct\Api\StockProviderInterface"
                type="Devsync\FeaturedProduct\Model\SalableQtyProvider"/>
</config>
