{
    "name": "devsync/module-featured-product",
    "description": "Displays a full-width featured product box as the first element of the Luma homepage content, with the salable quantity refreshed in real time (AJAX polling) without reloading the page.",
    "type": "magento2-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Devsync",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": ">=103.0.0",
        "magento/module-catalog": ">=104.0.0",
        "magento/module-store": ">=101.0.0",
        "magento/module-config": ">=101.2.0",
        "magento/module-backend": ">=102.0.0",
        "magento/module-ui": ">=101.2.0",
        "magento/module-catalog-inventory": ">=100.4.0",
        "magento/module-inventory-sales-api": ">=1.0.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Devsync\\FeaturedProduct\\": ""
        }
    }
}
